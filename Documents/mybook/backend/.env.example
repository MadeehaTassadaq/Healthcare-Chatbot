# RAG Chatbot Environment Variables
# Copy this file to .env and fill in the values

# Google Gemini API (for AI reasoning via OpenAI SDK format)
GEMINI_API_KEY=your_gemini_api_key_here

# Cohere API (for document embeddings)
COHERE_API_KEY=your_cohere_api_key_here

# Qdrant Vector Database
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=humanoid_robotics_docs

# Neon Postgres Database
NEON_DATABASE_URL=your_neon_database_url_here

# Application Settings (optional)
# LOG_LEVEL=INFO
# DEBUG=false
# PORT=8000

# ============================================
# Authentication Configuration
# ============================================

# Database (PostgreSQL) - for user profiles and sessions
DATABASE_URL=postgresql://user:password@localhost:5432/physical_ai_book

# JWT Configuration
# IMPORTANT: Generate a secure secret (at least 32 characters)
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption Key (32 bytes for AES-256)
# Use: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=your-32-byte-encryption-key-hex

# Better-Auth Configuration
# BETTER_AUTH_URL: The URL where your Better-Auth instance is running
# BETTER_AUTH_SECRET: The secret from your Better-Auth configuration (same as AUTH_SECRET in Better-Auth docs)
#                     This authenticates your backend when calling Better-Auth API
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your-better-auth-secret-from-better-auth-config

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10

# CORS
# Production URLs
CORS_ORIGINS=https://agreeable-sand-0efbb301e.4.azurestaticapps.net,http://localhost:3000,http://localhost:3001

# Security
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
